{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Brain Clash (Host)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),u=q.url==='/'?'/index.html':q.url,f=p.join('.',u),m={'html':'text/html','js':'application/javascript','css':'text/css'}[p.extname(f).slice(1)]||'application/octet-stream';fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');}else{r.writeHead(200,{'Content-Type':m});r.end(d);}});}).listen(8080)"],
      "port": 8080
    },
    {
      "name": "Brain Clash (Player)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),u=q.url==='/'?'/player.html':q.url,f=p.join('.',u),m={'html':'text/html','js':'application/javascript','css':'text/css'}[p.extname(f).slice(1)]||'application/octet-stream';fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');}else{r.writeHead(200,{'Content-Type':m});r.end(d);}});}).listen(8081)"],
      "port": 8081
    }
  ]
